REDIS_URL=redis://127.0.0.1:6379/0

JWT_ALGORITHM=HS256
H5_BASE_URL=http://127.0.0.1:23000
CORS_ALLOW_ORIGINS=http://localhost:23000,http://127.0.0.1:23000

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-me-before-shipping

NEXT_PUBLIC_APP_NAME=FoodOps Community
